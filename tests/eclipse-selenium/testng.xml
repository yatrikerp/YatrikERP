<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Yatrik ERP Test Suite" parallel="tests" thread-count="2">
    
    <listeners>
        <listener class-name="com.yatrik.listeners.TestListener"/>
    </listeners>
    
    <test name="Login Tests - Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.yatrik.tests.LoginTest"/>
        </classes>
    </test>
    
    <test name="Dashboard Tests - Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.yatrik.tests.DashboardTest"/>
        </classes>
    </test>
    
</suite>
